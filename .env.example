# Database Configuration
DB_USER=expense_user
DB_PASSWORD=expense_password
DB_NAME=expense_plan_db
DB_HOST=postgres
DB_PORT=5432

# PostgreSQL Configuration (for docker-compose)
POSTGRES_USER=expense_user
POSTGRES_PASSWORD=expense_password
POSTGRES_DB=expense_plan_db

# Application Configuration
PORT=3001
NODE_ENV=production

# Authentication
JWT_SECRET=your-secret-key-change-this-to-random-string

# Encryption Keys (generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-encryption-key-change-this-to-random-64-char-hex
ENCRYPTION_IV=your-encryption-iv-change-this-to-random-32-char-hex

# CORS Configuration (optional - defaults to localhost)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
